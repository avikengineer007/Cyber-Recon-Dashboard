# PostgreSQL connection string with pooling support (Neon or Supabase connection pooling)
DATABASE_URL="postgresql://recon_admin:recon_secure_password@localhost:5432/recon_db?pgbouncer=true&connect_timeout=15"

# PostgreSQL direct connection string (required for migrations via Prisma Client)
DIRECT_URL="postgresql://recon_admin:recon_secure_password@localhost:5432/recon_db"

# NextAuth configuration
NEXTAUTH_SECRET="your_next_auth_jwt_signing_secret_here_32_characters_minimum"
NEXTAUTH_URL="http://localhost:3000"

# Remote storage references (Optional - Vercel Blob or AWS S3 credentials)
BLOB_READ_WRITE_TOKEN="vercel_blob_token_here_if_using_vercel_blob"

# NIST NVD (National Vulnerability Database) API Key for real-time CVE search lookups
NVD_API_KEY="your_nvd_api_key_here"
